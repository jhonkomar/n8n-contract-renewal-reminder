    {
      "parameters": {
        "authentication": "oAuth2",
        "resource": "engagement",
        "type": "task",
        "dueDate": "={{ $(\"Set Urgency & Format Data\").item.json.endDate }}",
        "metadata": {
          "body": "=Kontrak {{ $(\"Set Urgency & Format Data\").item.json.dealName }} akan berakhir dalam {{ $(\"Set Urgency & Format Data\").item.json.daysUntilExpiry }} hari ({{ $(\"Set Urgency & Format Data\").item.json.endDate }}). Nilai: {{ $(\"Set Urgency & Format Data\").item.json.amountFormatted }}. Draft email renewal sudah disiapkan.",
          "forObjectType": "COMPANY",
          "status": "NOT_STARTED",
          "subject": "={{ $(\"Set Urgency & Format Data\").item.json.urgencyLabel }} — Renewal Reminder: {{ $(\"Set Urgency & Format Data\").item.json.dealName }}"
        },
        "additionalFields": {
          "associations": {
            "dealIds": "={{ $(\"Set Urgency & Format Data\").item.json.dealId }}"
          }
        }
